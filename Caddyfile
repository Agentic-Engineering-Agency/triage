# Snippets for frontend mode switching
# In static mode, config.json is served from /srv before SPA fallback
# In dev mode, config.json is proxied to Vite along with all other frontend requests

(dev-frontend) {
    # Dev-only override: Vite HMR needs 'unsafe-eval' in script-src for the
    # HMR runtime. Reuses the scheme-only connect-src wildcard already used
    # by the site-wide CSP. This snippet is never imported in production.
    header Content-Security-Policy "default-src 'self'; script-src 'self' 'unsafe-inline' 'unsafe-eval'; style-src 'self' 'unsafe-inline'; img-src 'self' data: blob:; connect-src 'self' ws: wss:; font-src 'self' data:; frame-ancestors 'none'"
    reverse_proxy vite:5173
}

(static-frontend) {
    handle /config.json {
        root * /srv
        file_server
    }
    root * /srv
    file_server
    try_files {path} /index.html
}

:3001 {
    # Compression
    encode gzip zstd

    # Security headers
    header {
        Strict-Transport-Security "max-age=31536000; includeSubDomains"
        X-Content-Type-Options "nosniff"
        X-Frame-Options "DENY"
        Referrer-Policy "strict-origin-when-cross-origin"
        Content-Security-Policy "default-src 'self'; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline'; img-src 'self' data: blob:; connect-src 'self' ws: wss:; font-src 'self' data:; frame-ancestors 'none'"
    }

    # --- Backend API routes (all proxied to runtime:4111) ---

    # registerApiRoute routes are served WITHOUT the /api prefix by Mastra.
    # Strip /api from the path for these specific route groups before proxying.

    # Observability API
    @obs_api path /api/observability/*
    handle @obs_api {
        uri replace /api/observability /observability
        reverse_proxy runtime:4111
    }

    # Projects API (project-routes.ts uses registerApiRoute('/projects/...'))
    @projects_api_prefixed path /api/projects /api/projects/*
    handle @projects_api_prefixed {
        uri replace /api/projects /projects
        reverse_proxy runtime:4111
    }

    # Integrations API
    @integrations_api path /api/integrations/*
    handle @integrations_api {
        uri replace /api/integrations /integrations
        reverse_proxy runtime:4111
    }

    # Mastra built-in API + inline routes (/api/agents/*, /api/workflows/*, /api/linear/*, /api/memory/*, etc.)
    handle /api/* {
        reverse_proxy runtime:4111 {
            flush_interval -1
        }
    }

    # Chat streaming endpoint (POST only — GET /chat goes to SPA)
    @chat_post {
        path /chat
        method POST
    }
    handle @chat_post {
        reverse_proxy runtime:4111 {
            flush_interval -1
        }
    }

    # Runtime health check
    handle /health {
        reverse_proxy runtime:4111
    }

    # Auth endpoints
    handle /auth/* {
        reverse_proxy runtime:4111 {
            flush_interval -1
        }
    }

    # Memory threads API (conversation history)
    handle /memory/threads/* {
        reverse_proxy runtime:4111 {
            flush_interval -1
        }
    }

    # Project management API — only proxy XHR/fetch (not browser navigation)
    @projects_api {
        path /projects /projects/*
        header Accept *application/json*
    }
    handle @projects_api {
        reverse_proxy runtime:4111
    }

    # Webhook callbacks (Linear, manual resume, etc.)
    handle /webhooks/* {
        reverse_proxy runtime:4111
    }

    # Frontend: static or dev mode
    handle {
        import dev-frontend
    }
}
