# Stage 1: Builder
FROM node:22-alpine AS builder
RUN apk add --no-cache git && npm install -g pnpm
WORKDIR /app
COPY . .
RUN if [ -f runtime/src/mastra/index.ts ]; then \
      cd runtime && npm ci && npx mastra build && \
      cp -r .mastra/output /app/output; \
    else \
      mkdir -p /app/output && \
      cp stubs/runtime/index.mjs /app/output/ && \
      cp stubs/runtime/package.json /app/output/; \
    fi

# Stage 2: Production
FROM node:22-alpine
RUN apk add --no-cache git
WORKDIR /app
COPY --from=builder /app/output/ ./
COPY runtime/init-db.mjs ./init-db.mjs
EXPOSE 4111
ENV PORT=4111 NODE_ENV=production
USER node
CMD ["sh", "-c", "node init-db.mjs && node index.mjs"]
