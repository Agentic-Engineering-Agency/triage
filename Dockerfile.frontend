# Stage 1: Builder
FROM node:22-alpine AS builder
WORKDIR /app
COPY . .
RUN if [ -f frontend/package.json ]; then \
      cd frontend && npm ci && npm run build && cp -r dist /app/dist; \
    else \
      cp -r stubs/frontend /app/dist; \
    fi

# Stage 2: Production
FROM caddy:2-alpine
COPY Caddyfile /etc/caddy/Caddyfile
COPY --from=builder /app/dist/ /srv/
EXPOSE 3001
