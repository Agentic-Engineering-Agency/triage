# ================================================================
# Triage SRE Agent — Environment Variables
# ================================================================
# Copy this file to .env and fill in real values:
#   cp .env.example .env
#
# Generate random secrets with:
#   openssl rand -hex 32
#
# NEVER commit .env — only .env.example with placeholder values.
# ================================================================

# === App Configuration ===
PORT=4111
NODE_ENV=production
LIBSQL_URL=http://libsql:8080

# === Auth (Better Auth) ===
BETTER_AUTH_SECRET=***
BETTER_AUTH_URL=http://localhost:3001

# === LLM / AI (OpenRouter) ===
# Get your key at https://openrouter.ai/settings/keys
OPENROUTER_API_KEY=***

# === Integrations: Linear ===
LINEAR_API_KEY=***

# === Integrations: Resend (Email) ===
RESEND_API_KEY=***
RESEND_FROM_EMAIL=triage@agenticengineering.lat  # Sender address for Resend emails

# === Integrations: Slack ===
SLACK_BOT_TOKEN=***
SLACK_CHANNEL_ID=CHANGEME
SLACK_SIGNING_SECRET=***

# === Integrations: Jira ===
JIRA_BASE_URL=https://your-domain.atlassian.net
JIRA_EMAIL=your-email@example.com
JIRA_API_TOKEN=***

# === Langfuse Core ===
# hint: openssl rand -hex 32 for ENCRYPTION_KEY, SALT, NEXTAUTH_SECRET
ENCRYPTION_KEY=CHANGEME
SALT=CHANGEME
NEXTAUTH_SECRET=***
NEXTAUTH_URL=http://localhost:3000
LANGFUSE_BASEURL=http://langfuse-web:3000
LANGFUSE_PUBLIC_KEY=CHANGEME
LANGFUSE_SECRET_KEY=***
TELEMETRY_ENABLED=true
LANGFUSE_ENABLE_EXPERIMENTAL_FEATURES=false

# === Langfuse Infrastructure ===
CLICKHOUSE_PASSWORD=***
REDIS_AUTH=***
MINIO_ROOT_USER=minio
MINIO_ROOT_PASSWORD=***
LANGFUSE_S3_EVENT_UPLOAD_SECRET_ACCESS_KEY=***
LANGFUSE_S3_MEDIA_UPLOAD_SECRET_ACCESS_KEY=***
LANGFUSE_S3_BATCH_EXPORT_SECRET_ACCESS_KEY=***
LANGFUSE_S3_BATCH_EXPORT_ENABLED=false

# === Langfuse Init (Headless Setup — auto-creates org/project/user) ===
LANGFUSE_INIT_ORG_ID=triage-org
LANGFUSE_INIT_ORG_NAME=Triage SRE
LANGFUSE_INIT_PROJECT_ID=triage-project
LANGFUSE_INIT_PROJECT_NAME=Triage Agent
LANGFUSE_INIT_PROJECT_PUBLIC_KEY=CHANGEME
LANGFUSE_INIT_PROJECT_SECRET_KEY=***
LANGFUSE_INIT_USER_EMAIL=admin@agenticengineering.lat
LANGFUSE_INIT_USER_NAME=Admin
LANGFUSE_INIT_USER_PASSWORD=***

# === Postgres (Langfuse backend DB) ===
POSTGRES_USER=postgres
POSTGRES_PASSWORD=***
POSTGRES_DB=langfuse

# === Frontend ===
# Valid values: static (production, serves built SPA) or dev (proxies to Vite HMR)
FRONTEND_MODE=static

# === Caddy ===
CADDY_PORT=3001
RUNTIME_HOST=runtime
RUNTIME_PORT=4111
