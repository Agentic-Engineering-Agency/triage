# ================================================================
# Triage SRE Agent — Environment Variables
# ================================================================
# Copy this file to .env and fill in real values:
#   cp .env.example .env
#
# Generate random secrets with:
#   openssl rand -hex 32
#
# NEVER commit .env — only .env.example with placeholder values.
# ================================================================

# === App Configuration ===
PORT=4111
NODE_ENV=production
LIBSQL_URL=http://libsql:8080

# === Authentication (Better Auth) ===
# Generate with: openssl rand -hex 32
BETTER_AUTH_SECRET=CHANGEME
BETTER_AUTH_URL=http://localhost:3001

# === LLM / AI (OpenRouter) ===
# Get your key at https://openrouter.ai/settings/keys
OPENROUTER_API_KEY=CHANGEME

# === Integrations ===

# === Integrations: Linear ===
# Get key at: your Linear workspace settings → API
# Team ID: go to your team dashboard → copy the team UUID from the URL
# Dashboard: https://linear.app/your-workspace/team/YOUR_TEAM_KEY/all
LINEAR_API_KEY=CHANGEME
LINEAR_TEAM_ID=645a639b-39e2-4abe-8ded-3346d2f79f9f  # Default: TRI team from agentic-engineering-agency
GITHUB_TOKEN=CHANGEME             # GitHub PAT for PR comments (repo scope)

# === Integrations: Resend (Email) ===
RESEND_API_KEY=CHANGEME
# Verified sender address for outbound triage notifications
RESEND_FROM_EMAIL=triage@agenticengineering.lat

# === Integrations: Slack ===
# Create a Slack app at https://api.slack.com/apps — Bot Token Scopes: chat:write
SLACK_BOT_TOKEN=CHANGEME
# Default channel ID for triage notifications (e.g. C07XXXXXXXX or D0XXXXXXXX for DMs)
SLACK_CHANNEL_ID=CHANGEME
# Signing secret from Slack app settings (for webhook verification)
SLACK_SIGNING_SECRET=CHANGEME
# Team member Slack user IDs (for @mentions in notifications)
# Find IDs: click a user profile in Slack → "..." → "Copy member ID"
SLACK_USER_FERNANDO=
SLACK_USER_KOKI=
SLACK_USER_CHENKO=
SLACK_USER_LALO=

# === Integrations: Jira ===
JIRA_BASE_URL=https://your-domain.atlassian.net
JIRA_EMAIL=your-email@example.com
JIRA_API_TOKEN=CHANGEME

# === Frontend ===
# Valid values: static (production, serves built SPA) or dev (proxies to Vite HMR)
FRONTEND_MODE=static

# === Caddy ===
CADDY_PORT=3001
RUNTIME_HOST=runtime
RUNTIME_PORT=4111
