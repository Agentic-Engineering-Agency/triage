# ================================================================
# Triage SRE Agent — Environment Variables
# ================================================================
# Copy this file to .env and fill in real values:
#   cp .env.example .env
#
# Generate random secrets with:
#   openssl rand -hex 32
#
# NEVER commit .env — only .env.example with placeholder values.
# ================================================================

# === App Configuration ===
PORT=4111
NODE_ENV=production
LIBSQL_URL=http://libsql:8080

# === Authentication (Better Auth) ===
# Generate with: openssl rand -hex 32
BETTER_AUTH_SECRET=CHANGEME
BETTER_AUTH_URL=http://localhost:3001

# === LLM / AI (OpenRouter) ===
# Get your key at https://openrouter.ai/settings/keys
OPENROUTER_API_KEY=CHANGEME

# === Integrations ===

# === Integrations: Linear ===
LINEAR_API_KEY=CHANGEME
GITHUB_TOKEN=CHANGEME             # GitHub PAT for PR comments (repo scope)

# === Integrations: Resend (Email) ===
RESEND_API_KEY=CHANGEME
# Verified sender address for outbound triage notifications
RESEND_FROM_EMAIL=triage@agenticengineering.lat

# === Integrations: Slack ===
SLACK_BOT_TOKEN=CHANGEME
SLACK_CHANNEL_ID=CHANGEME
SLACK_SIGNING_SECRET=CHANGEME

# === Integrations: Jira ===
JIRA_BASE_URL=https://your-domain.atlassian.net
JIRA_EMAIL=your-email@example.com
JIRA_API_TOKEN=CHANGEME

# === Cloudflare Tunnel ===
# Token for the triage-hackathon tunnel (routes langfuse.agenticengineering.lat → langfuse-web:3000)
# Get with: cloudflared tunnel token triage-hackathon
CLOUDFLARE_TUNNEL_TOKEN=CHANGEME

# === Langfuse Core ===
# Generate with: openssl rand -hex 32
ENCRYPTION_KEY=CHANGEME
SALT=CHANGEME
NEXTAUTH_SECRET=CHANGEME
NEXTAUTH_URL=http://localhost:3000
# External URL via Cloudflare Tunnel — used by OpenRouter broadcast and Mastra LangfuseExporter
LANGFUSE_BASEURL=https://langfuse.agenticengineering.lat
LANGFUSE_PUBLIC_KEY=CHANGEME
LANGFUSE_SECRET_KEY=CHANGEME
TELEMETRY_ENABLED=true
LANGFUSE_ENABLE_EXPERIMENTAL_FEATURES=false

# === Langfuse Infrastructure ===
# Generate with: openssl rand -hex 32
CLICKHOUSE_PASSWORD=CHANGEME
REDIS_AUTH=CHANGEME
MINIO_ROOT_USER=minio
MINIO_ROOT_PASSWORD=CHANGEME
LANGFUSE_S3_EVENT_UPLOAD_SECRET_ACCESS_KEY=CHANGEME
LANGFUSE_S3_MEDIA_UPLOAD_SECRET_ACCESS_KEY=CHANGEME
LANGFUSE_S3_BATCH_EXPORT_SECRET_ACCESS_KEY=CHANGEME
LANGFUSE_S3_BATCH_EXPORT_ENABLED=false

# === Langfuse Init (Headless Setup — auto-creates org/project/user) ===
LANGFUSE_INIT_ORG_ID=triage-org
LANGFUSE_INIT_ORG_NAME=Triage SRE
LANGFUSE_INIT_PROJECT_ID=triage-project
LANGFUSE_INIT_PROJECT_NAME=Triage Agent
LANGFUSE_INIT_PROJECT_PUBLIC_KEY=CHANGEME
LANGFUSE_INIT_PROJECT_SECRET_KEY=CHANGEME
LANGFUSE_INIT_USER_EMAIL=admin@agenticengineering.lat
LANGFUSE_INIT_USER_NAME=Admin
LANGFUSE_INIT_USER_PASSWORD=CHANGEME

# === Postgres (Langfuse backend DB) ===
POSTGRES_USER=postgres
POSTGRES_PASSWORD=CHANGEME
POSTGRES_DB=langfuse

# === Frontend ===
# Valid values: static (production, serves built SPA) or dev (proxies to Vite HMR)
FRONTEND_MODE=static

# === Caddy ===
CADDY_PORT=3001
RUNTIME_HOST=runtime
RUNTIME_PORT=4111

